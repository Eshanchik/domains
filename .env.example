# Copy to .env and adjust. Never commit a real .env (secrets stay out of git).

# --- Environment ---
ENVIRONMENT=development
DEBUG=false
TIMEZONE=Europe/Kyiv

# --- Postgres ---
POSTGRES_USER=domainguard
POSTGRES_PASSWORD=domainguard
POSTGRES_DB=domainguard
# App-side DSN (async driver). Host is the compose service name.
DATABASE_URL=postgresql+asyncpg://domainguard:domainguard@postgres:5432/domainguard

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Fernet master key for encrypting secrets at rest. Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DG_MASTER_KEY=

# --- HTTP ---
# Host port nginx is published on (maps to nginx:80).
HTTP_PORT=8080

# --- First admin (used by `make create-admin`) ---
DG_ADMIN_EMAIL=admin@example.com
DG_ADMIN_LOGIN=admin
# Set a strong password before running create-admin (min 8 chars).
DG_ADMIN_PASSWORD=
